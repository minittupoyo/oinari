---
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{
  filteredHeadings.length > 0 && (
    <nav aria-label="目次">
      <p class="text-md mb-2 font-medium">目次</p>
      <div class="space-y-1">
        {filteredHeadings.map((h) => (
          <ul
            class:list={[
              "text-sm leading-6 transition-colors duration-150 hover:text-purple-500!",
              h.depth === 2 && "text-zinc-700",
              h.depth === 3 && "ml-2 text-zinc-500! hover:opacity-80",
            ]}
          >
            <a href={`#${h.slug}`}>{h.text}</a>
          </ul>
        ))}
      </div>
    </nav>
  )
}
