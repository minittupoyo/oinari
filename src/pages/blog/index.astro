---
import Layout from "../../layouts/Layout.astro";
import BlogPost from "../../components/BlogPost.astro";
import { getPosts } from "../../lib/blog";

const posts = await getPosts();
---

<Layout title="記事一覧" description="投稿されている記事一覧">
  <section class="flex flex-col space-y-4 py-8">
    <h1 class="text-4xl font-bold">Blog</h1>
    <p class="text-lg font-medium text-zinc-700">現在{posts.length}個の記事があります</p>
  </section>
  <section class="flex flex-col py-8 border-t border-zinc-100">
    <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
      {
        posts.map((post) => (
          <BlogPost post={post} />
        ))
      }
    </div>
  </section>
</Layout>
